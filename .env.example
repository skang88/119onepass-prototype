# 119원패스 AI 플랫폼 프로토타입 환경 변수 설정 예시

# Gemini API Key (Google AI Studio에서 발급받은 API 키 입력)
GEMINI_API_KEY=your_gemini_api_key_here

# 로컬 Ollama 서버 주소 (기본값은 백엔드 소스코드 내 디폴트 값인 http://100.98.209.0/ollama 입니다)
# 로컬에서 실행 중인 경우 대개 http://localhost:11434 이나, Docker 내부에서는 host.docker.internal을 사용해 호스트에 접근해야 할 수 있습니다.
# OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=http://100.98.209.0/ollama
